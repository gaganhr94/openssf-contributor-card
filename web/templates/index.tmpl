{{define "pageTitle"}}OpenSSF Contributor Card{{end}}
{{define "pageDescription"}}Find your contributor card. {{.Total}} people across {{len .Projects}} OpenSSF projects.{{end}}
{{define "ogType"}}website{{end}}
{{define "pageURL"}}{{.SiteURL}}/{{end}}
{{define "ogImage"}}{{.SiteURL}}/og/index.jpg{{end}}

{{define "body"}}
<section class="hero">
  <img src="{{.BasePath}}/static/openssf-logo.svg" alt="OpenSSF" class="hero-logo" />
  <h1>Contributor Card</h1>
  <p class="lede">Find your card by GitHub username.</p>

  <div class="search-wrapper">
    <span class="search-icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
    </span>
    <input id="search" class="search" type="search" autocomplete="off" spellcheck="false"
           placeholder="Enter GitHub username (e.g. dlorenc, puerco)…"
           aria-label="Search by GitHub username"
           aria-controls="suggestions"
           aria-expanded="false" />
    <ul id="suggestions" class="suggestions" role="listbox" hidden></ul>
  </div>

  <p class="hero-stats">
    <strong>{{.Total}}</strong> contributors across <strong>{{len .Projects}}</strong> OpenSSF projects
  </p>
</section>

<script id="contrib-data" type="application/json">{{.SearchJSON}}</script>
<script>window.__BASE_PATH__ = {{.BasePath}};</script>
<script src="{{.BasePath}}/static/js/search.js" defer></script>
{{end}}
